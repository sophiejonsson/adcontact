# Adcontact environment variables
# Copy this file to .env.local and fill in the values

# ─── Application ────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://www.adcontact.se

# Legacy media fallback for preserved /media/... catalogue paths.
# Point this to the Orderland/legacy host that still contains:
# /media/catalog/product, /media/catalog/category, and /media/amfile/files.
ORDERLAND_MEDIA_ORIGIN=https://adcgam.hemsida.eu

# ─── Email / RFQ (choose one) ───────────────────────────────────
# Resend (recommended)
RESEND_API_KEY=re_xxxxxxxxxxxx
RFQ_EMAIL_RECIPIENT=rfq@adcontact.se

# SendGrid (alternative)
# SENDGRID_API_KEY=SG.xxxxxxxxxxxx

# ─── CRM / Backend (optional) ───────────────────────────────────
# Airtable
# AIRTABLE_API_KEY=patxxxxxxxxxxxxxxxx
# AIRTABLE_BASE_ID=appxxxxxxxxxxxxxxxx
# AIRTABLE_TABLE_ID=tblxxxxxxxxxxxxxxxx

# HubSpot
# HUBSPOT_ACCESS_TOKEN=pat-eu1-xxxxxxxxxxxx
# HUBSPOT_PORTAL_ID=12345678

# Supabase
# NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
# NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
# SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ─── Analytics (optional) ───────────────────────────────────────
# NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX
# NEXT_PUBLIC_GTM_ID=GTM-XXXXXXX

# ─── Product database (future) ──────────────────────────────────
# DATABASE_URL=postgresql://user:pass@host:5432/adcontact
