  {
    "name": "Ulmer Universal cutting machine SM 15 2PLC",
    "slug": "ulmer-universal-cutting-machine-sm-15-2plc",
    "sourcePath": "/webshop/ulmer-universal-cutting-machine-sm-15-2plc.html",
